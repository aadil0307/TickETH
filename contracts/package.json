{
  "name": "ticketh-contracts",
  "version": "1.0.0",
  "description": "TickETH NFT Ticketing Smart Contracts",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:coverage": "hardhat coverage",
    "deploy:local": "hardhat run scripts/deploy.ts",
    "deploy:amoy": "hardhat run scripts/deploy.ts --network amoy",
    "deploy:polygon": "hardhat run scripts/deploy.ts --network polygon",
    "deploy:thirdweb": "npx thirdweb deploy",
    "verify:amoy": "hardhat verify --network amoy",
    "clean": "hardhat clean"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.1.0",
    "@openzeppelin/contracts-upgradeable": "^5.1.0",
    "@openzeppelin/merkle-tree": "^1.0.8",
    "dotenv": "^16.4.7",
    "hardhat": "^2.22.0"
  }
}
