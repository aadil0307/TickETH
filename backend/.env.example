# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ── Blockchain ───────────────────────────────────────────────
POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology
POLYGON_MAINNET_RPC_URL=https://polygon-rpc.com
CHAIN_ID=80002
FACTORY_ADDRESS=0x...
PLATFORM_TREASURY=0x...
DEPLOYER_PRIVATE_KEY=0x...

# ── Redis / BullMQ ───────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-secret
JWT_EXPIRATION=7d

# ── App ──────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000

# ── IPFS / Pinata ────────────────────────────────────────────
# Get credentials at https://app.pinata.cloud/developers/api-keys
# Use either JWT (recommended) or API key + secret pair
PINATA_JWT=
PINATA_API_KEY=
PINATA_API_SECRET=
PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs

# ── Chain Listener ───────────────────────────────────────────
# Set to false to disable the on-chain event listener
CHAIN_LISTENER_ENABLED=true
# Set to a specific block number to resume from (0 = start from current block)
CHAIN_LISTENER_START_BLOCK=0

# ── Check-in HMAC ────────────────────────────────────────────
# Secret used to sign QR payloads. Falls back to JWT_SECRET if not set.
CHECKIN_HMAC_SECRET=
